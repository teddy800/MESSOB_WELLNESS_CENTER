// Prisma Schema for PostgreSQL
// Refactored from MySQL for full PostgreSQL compatibility

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// User Roles Enum - Defines access levels in the system (7-tier hierarchy)
enum UserRole {
  EXTERNAL_PATIENT  // Walk-in patients (no login, no organizational affiliation)
  STAFF             // Mesob employees seeking healthcare
  NURSE_OFFICER     // Nurses providing care
  MANAGER           // Center managers
  REGIONAL_OFFICE   // Regional managers
  FEDERAL_OFFICE    // Federal/national level
  SYSTEM_ADMIN      // System administrators
}

// Gender Enum
enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

// BMI Category Enum
enum BmiCategory {
  UNDERWEIGHT
  NORMAL
  OVERWEIGHT
  OBESITY
}

// Blood Pressure Category Enum
enum BloodPressureCategory {
  NORMAL
  ELEVATED
  HYPERTENSION_STAGE_1
  HYPERTENSION_STAGE_2
  HYPERTENSIVE_CRISIS
}

// Appointment Status Enum
enum AppointmentStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

// Center Status Enum
enum CenterStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

// User Model - Core identity and authentication
model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String?  @unique // Nullable for external patients
  password  String?  // Hashed password, nullable for external patients
  fullName  String
  role      UserRole @default(STAFF)
  
  // Employee and External Patient Fields
  employeeId String?  // Mesob employee ID (nullable)
  isExternal Boolean  @default(false) // True for walk-in external patients
  canLogin   Boolean  @default(true)  // False for external patients
  
  // Center Assignment
  centerId  String?  @db.Uuid // Nullable (null for external patients)
  
  // Demographics
  dateOfBirth DateTime? @db.Date
  gender      Gender?
  phone       String?
  
  // Emergency Contact
  emergencyContactName  String?
  emergencyContactPhone String?
  
  // Account Status
  isActive    Boolean  @default(true)
  isVerified  Boolean  @default(false)
  lastLoginAt DateTime? @db.Timestamptz(3)
  
  // Timestamps
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)
  
  // Relations
  center        Center? @relation(fields: [centerId], references: [id], onDelete: SetNull)
  healthProfile HealthProfile?
  auditLogs     AuditLog[]
  vitalsRecords VitalRecord[]
  appointments  Appointment[]
  recordedVitals VitalRecord[] @relation("RecordedBy")
  wellnessPlans WellnessPlan[]
  feedback      Feedback[]
  
  @@index([email])
  @@index([role])
  @@index([centerId])
  @@index([createdAt])
  @@index([employeeId])
  @@index([isExternal])
  @@map("users")
}

// Health Profile - One-to-one with User
model HealthProfile {
  id     String @id @default(uuid()) @db.Uuid
  userId String @unique @db.Uuid
  
  // Basic Health Information
  bloodType       String?
  allergies       String?
  chronicConditions String?
  medications     String?
  
  // Vitals History (stored as JSONB for flexibility and performance)
  vitalsHistory   Json? @db.JsonB
  
  // Timestamps
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)
  
  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@map("health_profiles")
}

// Audit Log - Compliance with Proclamation 1321/2024
model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @db.Uuid
  action    String   // e.g., "LOGIN", "REGISTER", "UPDATE_PROFILE", "ACCESS_DATA"
  resource  String?  // What was accessed (e.g., "USER", "HEALTH_PROFILE")
  details   Json?    @db.JsonB // Additional context
  ipAddress String?
  userAgent String?
  
  timestamp DateTime @default(now()) @db.Timestamptz(3)
  
  // Relations
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  @@index([userId])
  @@index([action])
  @@index([timestamp(sort: Desc)])
  @@map("audit_logs")
}

// Vital Record - Stores vitals history
model VitalRecord {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid // Patient whose vitals are recorded
  recordedBy String  @db.Uuid // Staff member who recorded the vitals
  
  // BMI Data
  weightKg  Float?   @db.DoublePrecision
  heightCm  Float?   @db.DoublePrecision
  bmi       Float?   @db.DoublePrecision
  bmiCategory BmiCategory?
  
  // Blood Pressure Data
  systolic  Int?
  diastolic Int?
  bpCategory BloodPressureCategory?
  
  // Additional Vitals
  heartRate Int?      // beats per minute
  temperature Float?  @db.DoublePrecision // celsius
  oxygenSaturation Int? // percentage
  
  // Metadata
  notes     String?
  recordedAt DateTime @default(now()) @db.Timestamptz(3)
  
  // Relations
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
  recorder  User @relation("RecordedBy", fields: [recordedBy], references: [id], onDelete: Restrict)
  
  @@index([userId])
  @@index([recordedBy])
  @@index([recordedAt(sort: Desc)])
  @@index([userId, recordedAt(sort: Desc)])
  @@map("vital_records")
}

// Appointment - Manages patient appointments
model Appointment {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid // Patient
  
  // Appointment Details
  scheduledAt DateTime @db.Timestamptz(3)
  reason      String
  status      AppointmentStatus @default(PENDING)
  
  // Additional Information
  notes       String?
  diagnosis   String?
  prescription String?
  
  // Status Tracking
  confirmedAt  DateTime? @db.Timestamptz(3)
  startedAt    DateTime? @db.Timestamptz(3)
  completedAt  DateTime? @db.Timestamptz(3)
  cancelledAt  DateTime? @db.Timestamptz(3)
  cancellationReason String?
  
  // SMS Reminder Tracking
  reminderSentAt DateTime? @db.Timestamptz(3)
  reminderCount  Int @default(0)
  lastReminderBy String? @db.Uuid // User who sent the last reminder
  
  // Timestamps
  createdAt   DateTime @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @db.Timestamptz(3)
  
  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([scheduledAt])
  @@index([status])
  @@index([userId, status])
  @@index([scheduledAt, status])
  @@map("appointments")
}

// Wellness Plan - Personalized wellness plans for users
model WellnessPlan {
  id       String @id @default(uuid()) @db.Uuid
  userId   String @db.Uuid
  
  // Plan Details
  planText String
  goals    String?
  duration Int?    // Duration in days
  
  // Status
  isActive Boolean @default(true)
  
  // Timestamps
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)
  
  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([isActive])
  @@index([userId, isActive])
  @@map("wellness_plans")
}

// Feedback - User feedback and ratings
model Feedback {
  id      String @id @default(uuid()) @db.Uuid
  userId  String @db.Uuid
  
  // NPS and Satisfaction Ratings
  npsScore        Int?    // 0-10 Net Promoter Score
  serviceQuality  Int?    // 1-5 rating
  staffBehavior   Int?    // 1-5 rating
  cleanliness     Int?    // 1-5 rating
  waitTime        Int?    // 1-5 rating
  
  // Feedback Details
  rating          Int?    // Average rating (for backward compatibility)
  comments        String? // Additional comments
  feedbackType    String? @default("SERVICE") // e.g., "SERVICE", "FACILITY", "STAFF"
  
  // Timestamps
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  
  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([npsScore])
  @@index([createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@map("feedback")
}

// Center - Health centers/facilities
model Center {
  id       String @id @default(uuid()) @db.Uuid
  
  // Basic Information
  name     String
  code     String @unique // Unique center code
  
  // Location
  region   String
  city     String
  address  String
  
  // Contact
  phone    String?
  email    String?
  
  // Status
  status   CenterStatus @default(ACTIVE)
  
  // Capacity
  capacity Int? // Maximum patients per day
  
  // Timestamps
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)
  
  // Relations
  staff    User[]
  
  @@index([region])
  @@index([status])
  @@index([code])
  @@index([region, status])
  @@map("centers")
}
